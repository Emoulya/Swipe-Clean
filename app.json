{
  "expo": {
    "name": "SwipeClean",
    "slug": "swipe-clean",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swipeclean",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SwipeClean memerlukan akses galeri untuk menampilkan dan mengelola foto dan video Anda.",
        "NSPhotoLibraryAddUsageDescription": "SwipeClean memerlukan izin ini untuk memulihkan file dari sampah."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.m_sabda.swipeclean"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 260
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "SwipeClean memerlukan akses galeri untuk menampilkan dan mengelola foto dan video Anda.",
          "savePhotosPermission": "SwipeClean memerlukan izin ini untuk memulihkan file dari sampah.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-video",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65665b0e-6c58-4b8b-a6c4-3e904ee20db4"
      }
    },
    "owner": "m_sabda"
  }
}
